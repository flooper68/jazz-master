{
  "name": "@jazz-master/codebase",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --filter './apps/*' build",
    "preview": "bun run --cwd apps/web preview",
    "deploy": "bun run --cwd apps/web deploy",
    "db:generate": "bun run --cwd apps/web db:generate",
    "db:migrate": "bun run --cwd apps/migration migrate",
    "regression:db": "bun apps/web/src/server/db/regression.ts",
    "lint": "oxlint",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "bun run typecheck && bun run lint && bun run test && bun run build",
    "check:e2e": "bun run --cwd apps/web e2e",
    "work:status": "bun scripts/work-status.js"
  },
  "devDependencies": {
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.9"
  }
}

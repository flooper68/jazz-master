---
const modules = [
  {
    title: 'Chord voicings',
    description: 'Build usable grips and voice-leading options you can recall on standards.',
  },
  {
    title: 'ii-V-I movement',
    description: 'Practice resolution paths across keys until the motion feels automatic.',
  },
  {
    title: 'Repertoire tracker',
    description: 'Keep standards, keys, weak spots, and next reps visible between sessions.',
  },
  {
    title: 'Ear training and takes',
    description: 'Connect what you hear, play, record, and review in the same practice loop.',
  },
]
---

<section id="modules" class="bg-stone-50">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase text-teal-800">Practice modules</p>
      <h2 class="mt-3 font-display text-3xl font-bold text-zinc-950 sm:text-4xl">
        Train the parts of jazz guitar that have to meet on the bandstand.
      </h2>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {modules.map((module) => (
        <article class="rounded-lg border border-zinc-200 bg-white p-5">
          <h3 class="text-lg font-bold text-zinc-950">{module.title}</h3>
          <p class="mt-2 leading-7 text-zinc-700">{module.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
